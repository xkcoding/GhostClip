{
  "$schema": "https://schema.tauri.app/config/2",
  "productName": "GhostClip",
  "version": "0.1.0",
  "identifier": "com.xkcoding.ghostclip",
  "build": {
    "frontendDist": "../src",
    "devUrl": "http://localhost:1420"
  },
  "app": {
    "withGlobalTauri": true,
    "macOSPrivateApi": true,
    "windows": [
      {
        "label": "main",
        "title": "GhostClip",
        "width": 360,
        "height": 680,
        "visible": false,
        "resizable": false,
        "decorations": false,
        "transparent": true,
        "alwaysOnTop": true,
        "skipTaskbar": true
      }
    ]
  },
  "bundle": {
    "active": true,
    "targets": "all",
    "resources": ["resources/**/*"],
    "icon": [
      "icons/32x32.png",
      "icons/128x128.png",
      "icons/128x128@2x.png",
      "icons/icon.icns",
      "icons/icon.ico"
    ],
    "macOS": {
      "minimumSystemVersion": "13.0",
      "signingIdentity": "-",
      "entitlements": "Entitlements.plist",
      "dmg": {
        "background": "icons/dmg_background.png"
      }
    }
  },
  "plugins": {}
}
