---
import LucideIcon from './LucideIcon.astro';
---

<section id="download" class="hero-section center">
  <div class="container hero">
    <img src="/logo.svg" alt="GhostClip Logo" width="80" height="80" class="hero-logo" />
    <h1 class="hero-title">选了 Android，不必放弃 Mac 体验</h1>
    <p class="hero-subtitle">
      Android 与 Mac 之间的文本剪贴板同步，局域网直连，数据不经云端
    </p>
    <button class="hero-brew" data-copy="brew install --cask xkcoding/tap/ghostclip" type="button">
      <LucideIcon name="terminal" size={14} color="#7A7A7A" />
      <code>brew install --cask xkcoding/tap/ghostclip</code>
      <span class="hero-brew-copy">
        <span class="hero-brew-copy-default"><LucideIcon name="copy" size={14} color="#9CA3AF" /></span>
        <span class="hero-brew-copy-done"><LucideIcon name="check" size={14} color="#22C55E" /></span>
      </span>
    </button>
    <div class="hero-actions">
      <a
        href="https://github.com/xkcoding/GhostClip/releases/latest"
        class="btn btn-primary"
      >
        <LucideIcon name="monitor" size={18} color="#FFFFFF" />
        下载 Mac 版
      </a>
      <a
        href="https://github.com/xkcoding/GhostClip/releases/latest"
        class="btn btn-secondary"
      >
        <LucideIcon name="smartphone" size={18} color="#0D0D0D" />
        下载 Android 版
      </a>
    </div>
  </div>
</section>

<style>
  .hero-section {
    padding: 120px 0 100px;
  }
  .hero {
    display: flex;
    flex-direction: column;
    align-items: center;
    gap: 32px;
  }
  .hero-logo {
    border-radius: 14px;
  }
  .hero-title {
    font-family: var(--font-heading);
    font-size: 48px;
    font-weight: 600;
    letter-spacing: -1px;
    line-height: 1.2;
  }
  .hero-subtitle {
    font-size: 18px;
    color: #7A7A7A;
    line-height: 1.6;
    margin-bottom: -16px;
  }
  .hero-brew {
    display: inline-flex;
    align-items: center;
    gap: 8px;
    background: #F5F5F5;
    border: 1px solid #E8E8E8;
    border-radius: 8px;
    padding: 10px 20px;
    cursor: pointer;
    transition: border-color 0.2s, background 0.2s;
  }
  .hero-brew:hover {
    background: #EFEFEF;
    border-color: #D1D5DB;
  }
  .hero-brew code {
    font-family: 'SF Mono', 'Fira Code', monospace;
    font-size: 14px;
    color: #374151;
    letter-spacing: -0.3px;
  }
  .hero-brew-copy {
    display: flex;
    align-items: center;
    margin-left: 4px;
  }
  .hero-brew-copy-done {
    display: none;
  }
  .hero-brew.copied .hero-brew-copy-default {
    display: none;
  }
  .hero-brew.copied .hero-brew-copy-done {
    display: flex;
  }
  .hero-actions {
    display: flex;
    gap: 16px;
    flex-wrap: wrap;
    justify-content: center;
  }
  .hero-actions .btn {
    font-family: var(--font-heading);
    padding: 14px 28px;
    border-radius: 8px;
  }

  @media (max-width: 768px) {
    .hero-section {
      padding: 80px 0 60px;
    }
    .hero-title {
      font-size: 32px;
    }
    .hero-subtitle {
      font-size: 16px;
    }
    .hero-brew {
      padding: 8px 14px;
    }
    .hero-brew code {
      font-size: 12px;
    }
  }
</style>
