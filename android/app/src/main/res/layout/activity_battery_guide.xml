<?xml version="1.0" encoding="utf-8"?>
<LinearLayout xmlns:android="http://schemas.android.com/apk/res/android"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:background="@color/bg_primary"
    android:orientation="vertical"
    android:fitsSystemWindows="true">

    <!-- Header: close + step label -->
    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="56dp"
        android:gravity="center_vertical"
        android:orientation="horizontal"
        android:paddingHorizontal="24dp">

        <ImageView
            android:id="@+id/btn_close"
            android:layout_width="22dp"
            android:layout_height="22dp"
            android:contentDescription="@string/battery_guide_skip"
            android:src="@drawable/ic_close"
            android:tint="@color/text_secondary" />

        <View
            android:layout_width="0dp"
            android:layout_height="0dp"
            android:layout_weight="1" />

        <TextView
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:text="@string/battery_guide_step_label"
            android:textColor="@color/text_tertiary"
            android:textSize="14sp" />
    </LinearLayout>

    <!-- Guide Body -->
    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="match_parent"
        android:gravity="center"
        android:orientation="vertical"
        android:paddingHorizontal="32dp"
        android:paddingTop="24dp"
        android:paddingBottom="32dp">

        <!-- Hero Icon -->
        <FrameLayout
            android:layout_width="120dp"
            android:layout_height="120dp"
            android:background="@drawable/bg_hero_battery">

            <ImageView
                android:layout_width="56dp"
                android:layout_height="56dp"
                android:layout_gravity="center"
                android:src="@drawable/ic_battery_charging"
                android:tint="@color/warning" />
        </FrameLayout>

        <!-- Title + Description -->
        <TextView
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:layout_marginTop="32dp"
            android:fontFamily="sans-serif-medium"
            android:letterSpacing="-0.02"
            android:text="@string/battery_guide_title"
            android:textColor="@color/text_primary"
            android:textSize="24sp"
            android:textStyle="bold" />

        <TextView
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:layout_marginTop="12dp"
            android:gravity="center"
            android:lineSpacingMultiplier="1.5"
            android:text="@string/battery_guide_desc"
            android:textColor="@color/text_secondary"
            android:textSize="15sp" />

        <!-- Steps -->
        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:layout_marginTop="32dp"
            android:orientation="vertical"
            android:paddingHorizontal="8dp">

            <TextView
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:lineSpacingMultiplier="1.6"
                android:text="@string/battery_guide_step1"
                android:textColor="@color/text_primary"
                android:textSize="14sp" />

            <TextView
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:layout_marginTop="8dp"
                android:lineSpacingMultiplier="1.6"
                android:text="@string/battery_guide_step2"
                android:textColor="@color/text_primary"
                android:textSize="14sp" />
        </LinearLayout>

        <!-- Success message (hidden by default) -->
        <TextView
            android:id="@+id/text_success"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:layout_marginTop="24dp"
            android:gravity="center"
            android:text="@string/battery_guide_success"
            android:textColor="@color/accent"
            android:textSize="16sp"
            android:textStyle="bold"
            android:visibility="gone" />

        <!-- Spacer -->
        <View
            android:layout_width="0dp"
            android:layout_height="0dp"
            android:layout_weight="1" />

        <!-- CTA Button -->
        <LinearLayout
            android:id="@+id/btn_go_settings"
            android:layout_width="match_parent"
            android:layout_height="52dp"
            android:background="@drawable/bg_btn_warning"
            android:clickable="true"
            android:focusable="true"
            android:gravity="center"
            android:orientation="horizontal">

            <ImageView
                android:layout_width="18dp"
                android:layout_height="18dp"
                android:src="@drawable/ic_external_link"
                android:tint="@color/text_on_accent" />

            <TextView
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:layout_marginStart="8dp"
                android:text="@string/battery_guide_cta"
                android:textColor="@color/text_on_accent"
                android:textSize="16sp"
                android:textStyle="bold" />
        </LinearLayout>

        <!-- Skip Link -->
        <TextView
            android:id="@+id/btn_skip"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:layout_marginTop="16dp"
            android:clickable="true"
            android:focusable="true"
            android:padding="8dp"
            android:text="@string/battery_guide_skip"
            android:textColor="@color/text_tertiary"
            android:textSize="14sp" />
    </LinearLayout>
</LinearLayout>
